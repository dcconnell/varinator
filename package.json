{
  "name": "varinator",
  "displayName": "Varinator",
  "description": "Syntax highlights C# variables based on their inferred data type using OmniSharp/Roslyn for deep type inference.",
  "version": "0.1.0",
  "publisher": "MelodicCode",
  "repository": {
    "type": "git",
    "url": "https://github.com/dcconnell/varinator"
  },
  "icon": "images/icon.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:csharp"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Varinator",
      "properties": {
        "varinator.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable Varinator type-based variable highlighting."
        },
        "varinator.typeColors": {
          "type": "object",
          "description": "Map of C# type names to hex color codes. Supports primitives, generics (e.g. 'List<string>'), and custom types. Generic fallback: if 'List<string>' is not defined, falls back to 'List'.",
          "default": {
            "int": "#4FC1FF",
            "Int32": "#4FC1FF",
            "long": "#4FC1FF",
            "Int64": "#4FC1FF",
            "short": "#4FC1FF",
            "Int16": "#4FC1FF",
            "byte": "#4FC1FF",
            "Byte": "#4FC1FF",
            "sbyte": "#4FC1FF",
            "SByte": "#4FC1FF",
            "uint": "#4FC1FF",
            "UInt32": "#4FC1FF",
            "ulong": "#4FC1FF",
            "UInt64": "#4FC1FF",
            "ushort": "#4FC1FF",
            "UInt16": "#4FC1FF",
            "float": "#B5CEA8",
            "Single": "#B5CEA8",
            "double": "#B5CEA8",
            "Double": "#B5CEA8",
            "decimal": "#B5CEA8",
            "Decimal": "#B5CEA8",
            "string": "#CE9178",
            "String": "#CE9178",
            "char": "#CE9178",
            "Char": "#CE9178",
            "bool": "#569CD6",
            "Boolean": "#569CD6",
            "object": "#9CDCFE",
            "dynamic": "#C586C0",
            "var": "#9CDCFE",
            "void": "#808080",
            "List": "#DCDCAA",
            "List<int>": "#4FC1AA",
            "List<string>": "#CEA178",
            "Dictionary": "#D7BA7D",
            "HashSet": "#D4A0D4",
            "Queue": "#70C0B1",
            "Stack": "#70B1C0",
            "Array": "#DCDCAA",
            "IEnumerable": "#C8C864",
            "IList": "#DCDCAA",
            "IDictionary": "#D7BA7D",
            "ICollection": "#C8C864",
            "Task": "#FF8C00",
            "Task<bool>": "#569CF6",
            "Task<int>": "#4FC1EE",
            "Task<string>": "#CEA1A8",
            "ValueTask": "#FF8C00",
            "Nullable": "#A0A0A0",
            "Guid": "#DA70D6",
            "DateTime": "#6796E6",
            "DateTimeOffset": "#6796E6",
            "TimeSpan": "#6796E6",
            "StringBuilder": "#CE9178",
            "Stream": "#70C0B1",
            "HttpClient": "#FF6347",
            "CancellationToken": "#FFD700",
            "ILogger": "#98FB98",
            "Exception": "#FF4444",
            "Span": "#20B2AA",
            "ReadOnlySpan": "#20B2AA",
            "Memory": "#20B2AA",
            "ReadOnlyMemory": "#20B2AA",
            "Tuple": "#DEB887",
            "Action": "#C586C0",
            "Func": "#C586C0",
            "IDisposable": "#A0A0A0",
            "IAsyncDisposable": "#A0A0A0"
          },
          "additionalProperties": {
            "type": "string",
            "format": "color",
            "pattern": "^#[0-9a-fA-F]{6}$"
          }
        },
        "varinator.highlightStyle": {
          "type": "string",
          "enum": [
            "foreground",
            "underline",
            "background",
            "border"
          ],
          "default": "foreground",
          "description": "How to apply the type color to variable names."
        },
        "varinator.underlineWidth": {
          "type": "string",
          "enum": [
            "1px",
            "2px",
            "3px"
          ],
          "default": "2px",
          "description": "Width of the underline when using 'underline' highlight style."
        },
        "varinator.backgroundOpacity": {
          "type": "number",
          "default": 0.15,
          "minimum": 0.05,
          "maximum": 1.0,
          "description": "Opacity of the background color when using 'background' highlight style."
        },
        "varinator.debounceMs": {
          "type": "number",
          "default": 300,
          "minimum": 100,
          "maximum": 5000,
          "description": "Debounce delay in milliseconds before re-analyzing the document after changes."
        }
      }
    },
    "commands": [
      {
        "command": "varinator.toggle",
        "title": "Varinator: Toggle Highlighting"
      },
      {
        "command": "varinator.refresh",
        "title": "Varinator: Refresh Type Highlighting"
      },
      {
        "command": "varinator.showTypeAtCursor",
        "title": "Varinator: Show Inferred Type at Cursor"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.3.0"
  }
}
