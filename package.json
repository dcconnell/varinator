{
  "name": "varinator",
  "displayName": "Varinator",
  "description": "Syntax highlights C# variables based on their inferred data type using OmniSharp/Roslyn for deep type inference.",
  "version": "0.1.1",
  "publisher": "MelodicCode",
  "repository": {
    "type": "git",
    "url": "https://github.com/dcconnell/varinator"
  },
  "icon": "images/icon.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:csharp"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Varinator",
      "properties": {
        "varinator.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable Varinator type-based variable highlighting."
        },
        "varinator.typeColors": {
          "type": "object",
          "description": "Map of C# type names to hex color codes. Supports primitives, generics (e.g. 'List<string>'), and custom types. Generic fallback: if 'List<string>' is not defined, falls back to 'List'.",
          "description (value types = greens, reference types = reds)": "Color convention: green shades for value types (structs), red shades for reference types (classes/interfaces/delegates).",
          "default": {
            "_comment_value_types": "--- VALUE TYPES (structs) = GREENS ---",
            "int": "#4CAF50",
            "Int32": "#4CAF50",
            "long": "#388E3C",
            "Int64": "#388E3C",
            "short": "#66BB6A",
            "Int16": "#66BB6A",
            "byte": "#81C784",
            "Byte": "#81C784",
            "sbyte": "#A5D6A7",
            "SByte": "#A5D6A7",
            "uint": "#43A047",
            "UInt32": "#43A047",
            "ulong": "#2E7D32",
            "UInt64": "#2E7D32",
            "ushort": "#558B2F",
            "UInt16": "#558B2F",
            "nint": "#4CAF50",
            "nuint": "#43A047",
            "float": "#8BC34A",
            "Single": "#8BC34A",
            "double": "#9CCC65",
            "Double": "#9CCC65",
            "decimal": "#7CB342",
            "Decimal": "#7CB342",
            "bool": "#00E676",
            "Boolean": "#00E676",
            "char": "#69F0AE",
            "Char": "#69F0AE",
            "Guid": "#00C853",
            "DateTime": "#26A69A",
            "DateTimeOffset": "#009688",
            "TimeSpan": "#00897B",
            "Nullable": "#B2FF59",
            "ValueTask": "#CCFF90",
            "CancellationToken": "#76FF03",
            "Span": "#1DE9B6",
            "ReadOnlySpan": "#00BFA5",
            "Memory": "#64FFDA",
            "ReadOnlyMemory": "#80CBC4",
            "KeyValuePair": "#4DB6AC",
            "ValueTuple": "#26A69A",

            "_comment_reference_types": "--- REFERENCE TYPES (classes/interfaces/delegates/records) = REDS ---",
            "string": "#CE9178",
            "String": "#CE9178",
            "StringBuilder": "#CE9178",
            "object": "#F44336",
            "dynamic": "#FF5252",
            "var": "#E0E0E0",
            "void": "#808080",
            "List": "#EF5350",
            "List<int>": "#E53935",
            "List<string>": "#FF7043",
            "Dictionary": "#FF6E40",
            "HashSet": "#E64A19",
            "Queue": "#D84315",
            "Stack": "#FF5722",
            "Array": "#FF7043",
            "LinkedList": "#EF5350",
            "SortedList": "#E53935",
            "SortedDictionary": "#FF6E40",
            "SortedSet": "#E64A19",
            "ObservableCollection": "#EF5350",
            "ConcurrentDictionary": "#FF6E40",
            "ConcurrentQueue": "#D84315",
            "ConcurrentStack": "#FF5722",
            "ConcurrentBag": "#E64A19",
            "IEnumerable": "#EF9A9A",
            "IList": "#E57373",
            "IDictionary": "#FFAB91",
            "ICollection": "#EF9A9A",
            "IReadOnlyList": "#E57373",
            "IReadOnlyDictionary": "#FFAB91",
            "IReadOnlyCollection": "#EF9A9A",
            "Task": "#D32F2F",
            "Task<bool>": "#C62828",
            "Task<int>": "#E53935",
            "Task<string>": "#FF1744",
            "Stream": "#FF8A80",
            "MemoryStream": "#FF8A80",
            "FileStream": "#FF8A80",
            "HttpClient": "#FF5252",
            "HttpResponseMessage": "#FF5252",
            "HttpRequestMessage": "#FF5252",
            "ILogger": "#FFCDD2",
            "Exception": "#B71C1C",
            "ArgumentException": "#B71C1C",
            "InvalidOperationException": "#B71C1C",
            "NullReferenceException": "#B71C1C",
            "Tuple": "#FF6E40",
            "Action": "#FF4081",
            "Func": "#F50057",
            "Delegate": "#F50057",
            "EventHandler": "#FF4081",
            "IDisposable": "#E57373",
            "IAsyncDisposable": "#EF9A9A"
          },
          "additionalProperties": {
            "type": "string",
            "format": "color",
            "pattern": "^#[0-9a-fA-F]{6}$"
          }
        },
        "varinator.highlightStyle": {
          "type": "string",
          "enum": [
            "foreground",
            "underline",
            "background",
            "border"
          ],
          "default": "foreground",
          "description": "How to apply the type color to variable names."
        },
        "varinator.underlineWidth": {
          "type": "string",
          "enum": [
            "1px",
            "2px",
            "3px"
          ],
          "default": "2px",
          "description": "Width of the underline when using 'underline' highlight style."
        },
        "varinator.backgroundOpacity": {
          "type": "number",
          "default": 0.15,
          "minimum": 0.05,
          "maximum": 1.0,
          "description": "Opacity of the background color when using 'background' highlight style."
        },
        "varinator.debounceMs": {
          "type": "number",
          "default": 300,
          "minimum": 100,
          "maximum": 5000,
          "description": "Debounce delay in milliseconds before re-analyzing the document after changes."
        }
      }
    },
    "commands": [
      {
        "command": "varinator.toggle",
        "title": "Varinator: Toggle Highlighting"
      },
      {
        "command": "varinator.refresh",
        "title": "Varinator: Refresh Type Highlighting"
      },
      {
        "command": "varinator.showTypeAtCursor",
        "title": "Varinator: Show Inferred Type at Cursor"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.3.0"
  }
}
